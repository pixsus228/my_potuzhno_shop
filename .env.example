# ──────────────────────────────────────────────────────────────
# Шаблон змінних оточення.
# Скопіюй цей файл у .env і підстав свої значення:
#   cp .env.example .env        (macOS / Linux)
#   copy .env.example .env      (Windows)
# Файл .env у git НЕ потрапляє (див. .gitignore).
# ──────────────────────────────────────────────────────────────

# Django
DJANGO_SECRET_KEY=змінити-на-випадковий-рядок
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL (співпадає з docker-compose.yml)
POSTGRES_DB=cinehub
POSTGRES_USER=cinehub
POSTGRES_PASSWORD=cinehub
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
